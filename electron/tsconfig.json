{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "outDir": "../dist-electron",
    "baseUrl": ".",
    "paths": {
      "@types": ["../src/types"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
